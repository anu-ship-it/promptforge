{
  "version": "1.0",
  "project": "PromptForge",

  "agents": {
    "maxConcurrent": 3,
    "retryOnFailure": true,
    "maxRetries": 1,
    "timeoutSeconds": 300
  },

  "permissions": {
    "allowFileWrite": true,
    "allowBashExecution": true,
    "allowNetworkAccess": false,
    "outputDirectory": "./output"
  },

  "context": {
    "alwaysInclude": [
      ".claude/agents/orchestrator.md"
    ],
    "skills": [
      ".claude/skills/react-component.md",
      ".claude/skills/api-design.md",
      ".claude/skills/db-schema.md",
      ".claude/skills/test-writing.md"
    ]
  },

  "generation": {
    "noPlaceholders": true,
    "noTruncation": true,
    "noTodoComments": true,
    "requireFullImplementation": true
  },

  "hooks": {
    "afterArchitect": "validate_spec",
    "afterCodeGeneration": "run_lint",
    "afterAll": "commit_to_github"
  }
}
